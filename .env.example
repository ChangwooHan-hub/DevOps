PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uwb
DATABASE_SSL=false
WEBHOOK_SECRET=replace-me
GITHUB_APP_ID=0
GITHUB_APP_PRIVATE_KEY=replace-me
GITHUB_TOKEN=
GITHUB_WEBHOOK_ALLOWLIST=issues,pull_request,issue_comment,check_suite,check_run,push
GITHUB_REPOSITORY_ALLOWLIST=
GITHUB_INSTALLATION_ALLOWLIST=
REDIS_URL=redis://127.0.0.1:6379
WEBHOOK_QUEUE_ENABLED=true
ORCHESTRATOR_QUEUE_ENABLED=true
LLM_PROVIDER=mock
LLM_GATEWAY_URL=http://127.0.0.1:3003
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_REQUEST_TIMEOUT_MS=30000
AGENT_DEFAULT_MODEL=gpt-5.4
AGENTS_SPEC_PATH=agents.md
AGENTS_SPEC_REQUIRED=true
RUNNER_ALLOW_MOCK_EXECUTION=false
RUNNER_MAX_RUNTIME_SECONDS=3600
RUNNER_MAX_CHANGED_FILES=50
RUNNER_MAX_LOC_DELTA=2000
RUNNER_MAX_LLM_CALLS=100
RUNNER_SERVICE_URL=http://127.0.0.1:3002
RUNNER_AUTOTRIGGER_ENABLED=true
RUNNER_AUTOTRIGGER_OPEN_PR=true
RUNNER_AUTOTRIGGER_DRAFT_PR=true
RUNNER_AUTOTRIGGER_DRY_RUN=false
RUNNER_AUTOTRIGGER_VALIDATION_ENABLED=false
RUNNER_REPOSITORY_PATH_MAP={}
RUNNER_DEFAULT_REPOSITORY_PATH=
RUNNER_REPOSITORY_BASE_DIR=
VALIDATION_TIMEOUT_SECONDS=900
VALIDATION_LINT_COMMAND=cmd /c npm.cmd run lint
VALIDATION_TYPECHECK_COMMAND=cmd /c npm.cmd run build
VALIDATION_TEST_COMMAND=cmd /c npm.cmd test
